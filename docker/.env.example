# VideoInsight environment template.
#
# This is the complete list of supported Docker/runtime settings. Local
# development uses this file plus docker/.env.dev. Production uses this file
# plus an ignored docker/.env.prod copied from this template.
#
# Keep development defaults simple so a new contributor can run `just up`
# without creating secrets. Override production values in docker/.env.prod.

# Image settings.
# Development compose builds local images, but production uses this repository
# as the base name for GHCR images:
#   ${IMAGE_REPOSITORY}-backend:${IMAGE_TAG}
#   ${IMAGE_REPOSITORY}-frontend:${IMAGE_TAG}
# Production example:
#   IMAGE_REPOSITORY=ghcr.io/OWNER/video-insight
IMAGE_REPOSITORY=videoinsight
IMAGE_TAG=latest

# Host ports used by the production compose stack. The dev stack exposes its
# usual service ports directly: frontend 5173, backend 8000, MinIO 9000/9001.
APP_PORT=8080
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# PostgreSQL. These defaults are intentionally simple for local development.
# Production must override POSTGRES_PASSWORD.
POSTGRES_USER=videoinsight
POSTGRES_PASSWORD=videoinsight
POSTGRES_DB=videoinsight
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgresql:5432/${POSTGRES_DB}

# Web/API settings.
# Production should override CORS_ORIGINS and SECRET_KEY.
# Example:
#   CORS_ORIGINS=["https://app.example.com"]
CORS_ORIGINS=["http://localhost:5173"]
VITE_API_URL=
VITE_ALLOWED_HOSTS=
BACKEND_URL=http://backend:8000
SECRET_KEY=change-me-in-real-environments

# Seeded admin account. Startup creates or updates this admin user.
# Dev default login: admin / admin
# Production must override ADMIN_PASSWORD.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
DEFAULT_GROUP_NAME=Default

# MinIO/S3-compatible storage.
# Production must override MINIO_ROOT_PASSWORD and usually MINIO_PUBLIC_ENDPOINT.
# If Cloudflared terminates HTTPS while Docker talks to MinIO over HTTP:
#   MINIO_SECURE=false
#   MINIO_PUBLIC_SECURE=true
#   MINIO_PUBLIC_ENDPOINT=media.example.com
MINIO_ROOT_USER=videoinsight
MINIO_ROOT_PASSWORD=videoinsight-secret
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET=videos
MINIO_SECURE=false
MINIO_PUBLIC_SECURE=false
